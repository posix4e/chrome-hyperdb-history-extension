{
  "manifest_version": 3,
  "name": "HyperDB History Sync",
  "version": "1.0",
  "description": "Stores browsing history in HyperDB for P2P sharing across devices",
  "permissions": [
    "history",
    "storage",
    "tabs",
    "activeTab"
  ],
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}