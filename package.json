{
  "name": "hyperdb-history-sync",
  "version": "1.0.0",
  "description": "Chrome extension that stores browsing history in HyperDB for P2P sharing",
  "main": "background.js",
  "scripts": {
    "build": "echo 'No build step required'",
    "test": "playwright test",
    "test:debug": "playwright test --debug",
    "test:real-world": "playwright test tests/real-world-sync.spec.js",
    "start:staging-peer": "cd staging-peer && npm start"
  },
  "dependencies": {
    "hypercore": "^10.0.0",
    "hyperbee": "^2.0.0",
    "hyperswarm": "^4.0.0",
    "random-access-memory": "^6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "playwright": "^1.40.0",
    "playwright-core": "^1.40.0"
  }
}