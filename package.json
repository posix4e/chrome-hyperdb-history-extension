{
  "name": "hyperdb-history-sync",
  "version": "1.0.0",
  "description": "Chrome extension that stores browsing history in HyperDB for P2P sharing",
  "main": "background.js",
  "type": "module",
  "scripts": {
    "build": "echo 'No build step required'",
    "start": "node server.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "package": "zip -r extension.zip manifest.json js/ images/ popup.html"
  },
  "dependencies": {
    "hyperbee": "^2.0.0",
    "hypercore": "^10.0.0",
    "hyperswarm": "^4.0.0",
    "random-access-memory": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@playwright/test": "^1.51.1",
    "eslint": "^9.24.0",
    "eslint-plugin-playwright": "^2.2.0",
    "globals": "^16.0.0",
    "playwright": "^1.51.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://<secret_hidden>@github.com/posix4e/chrome-hyperdb-history-extension.git"
  },
  "keywords": [
    "chrome-extension",
    "p2p",
    "hyperdb",
    "history-sync"
  ],
